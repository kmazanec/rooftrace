<main class="jobs-new">
  <h1>New roof measurement</h1>

  <% if @job.errors.any? %>
    <div class="jobs-errors" role="alert">
      <% @job.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @job, url: jobs_path do |f| %>
    <div>
      <%= f.label :address, "Property address" %>
      <%= f.text_field :address,
            autofocus: true,
            placeholder: "123 Main St, Springfield, IL 62701" %>
      <p class="jobs-new__hint">
        Try a US residential address; supports street + city/state + optional ZIP.
      </p>
    </div>
    <%= f.submit "Start measurement", class: "report-cta" %>
  <% end %>
</main>
