# Copy to ops/.env.production on the droplet and fill in real values.
# ops/.env.production is gitignored — never commit real secrets.
#
#   cp ops/.env.example ops/.env.production
#   # edit ops/.env.production
#   docker compose -f ops/compose.prod.yaml --env-file ops/.env.production up -d --build

# Postgres password (the rooftrace DB role).
POSTGRES_PASSWORD=change-me-strong-password

# Rails secret_key_base — generate with: bin/rails secret
SECRET_KEY_BASE=change-me-run-bin-rails-secret

# Shared secret for the Rails ↔ sidecar bearer auth (ADR-008).
# Generate with: openssl rand -hex 32
SIDECAR_SHARED_SECRET=change-me-openssl-rand-hex-32

# DigitalOcean Spaces (ADR-010, amended in F-01: ONE bucket partitioned by
# key prefix — uploads/ cache/ artifacts/ backups/). Endpoint/region match
# the Space's region.
STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
STORAGE_REGION=nyc3
STORAGE_BUCKET=rooftrace
STORAGE_ACCESS_KEY=change-me-spaces-access-key
STORAGE_SECRET_KEY=change-me-spaces-secret-key

# Deployed git SHA (surfaced in /health). Set at deploy time, e.g.:
#   GIT_SHA=$(git rev-parse --short HEAD)
GIT_SHA=unknown
