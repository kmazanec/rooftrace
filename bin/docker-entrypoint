#!/bin/bash -e

# If we're booting the Rails server (directly or via Thruster), prepare the
# database first. Idempotent — db:prepare is a no-op when migrations are
# already applied. Covers both:
#   ./bin/rails server ...
#   ./bin/thrust ./bin/rails server ...
if [[ "$*" == *"./bin/rails server"* ]] || [[ "$*" == *"./bin/thrust ./bin/rails server"* ]]; then
  ./bin/rails db:prepare
fi

exec "${@}"
