<%#
  Claim-defensible methodology footnote for the PDF (ADR-018).

  Locals:
    methodology_sentences  Array<String> — from ReportMethodology.call(measurement)

  Renders nothing when methodology_sentences is blank.
%>
<% sentences = Array(methodology_sentences) %>
<% unless sentences.empty? %>
  <div class="report-methodology print-only">
    <h3 class="report-section-heading">Methodology</h3>
    <p class="report-methodology-text">
      <%= safe_join(sentences, " ") %>
    </p>
  </div>
<% end %>
