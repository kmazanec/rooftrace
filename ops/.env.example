# Template for the operator-placed secret file at /etc/rooftrace/.env on the
# droplet. Per the droplet convention (.infra/NEW_APP.md §4.1), the operator
# places this ONCE as root:
#
#   sudo install -m 640 -o root -g gitlab-runner /dev/stdin /etc/rooftrace/.env <<'EOF'
#   ...contents below, with real values...
#   EOF
#   sudo /usr/local/sbin/audit-secrets.sh   # verify perms
#
# The GitLab CI deploy job (infra/deploy.sh) reads it via compose `env_file:`.
# It is never committed and never lives in a bind-mount the container can write.
# GIT_SHA is rewritten by infra/deploy.sh on each deploy (the deployed SHA).

# --- Postgres ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Database URLs (composed from POSTGRES_PASSWORD; the host is the
#     rooftrace-postgres container on the internal network). Rails reads the
#     primary DATABASE_URL; Solid Queue/Cache/Cable need their own pools. ---
DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production
QUEUE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_queue
CACHE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cache
CABLE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cable

# --- Rails ---
# Generate with: bin/rails secret
SECRET_KEY_BASE=change-me-run-bin-rails-secret

# --- Rails <-> sidecar bearer (ADR-008). Generate: openssl rand -hex 32 ---
SIDECAR_SHARED_SECRET=change-me-openssl-rand-hex-32

# --- Dev login (ADR-016) — REQUIRED in production ---
# The submit surface is gated by a single dev login; the app raises at boot if
# these are unset in production. DEMO_PASSWORD_DIGEST is a bcrypt digest:
#   bin/rails runner 'puts BCrypt::Password.create("the-demo-password")'
DEMO_USERNAME=demo
DEMO_PASSWORD_DIGEST=change-me-bcrypt-digest

# --- VLM feature detection (ADR-006) — REQUIRED in production ---
# OpenRouter API key (openrouter.ai/keys). The detector reaches every candidate
# model (Gemini, GPT-4o, Claude, …) through OpenRouter's OpenAI-compatible API.
# The app raises at boot if unset in prod.
OPENROUTER_API_KEY=change-me-openrouter-api-key
# Optional: model slug to use (default google/gemini-2.5-flash).
# OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Mapbox satellite (ADR-002, as amended) — REQUIRED in production ---
# TWO tokens, split by EXPOSURE (not by feature):
#
#   MAPBOX_PUBLIC_TOKEN  — BROWSER only. Embedded in the report-viewer page so the
#     browser's MapLibre fetches satellite raster tiles. Use a pk.* token that is
#     URL-restricted to your domain(s); it is not a secret.
#   MAPBOX_PRIVATE_TOKEN — SERVER only. Every server-side Mapbox call uses it: the
#     sidecar's geometry-pipeline imagery (Static Images — Mapbox replaced NAIP,
#     whose AWS buckets are requester-pays) + its top-down map render, and Rails'
#     PDF static-image fallback + the address-entry autocomplete (/suggest). Keep
#     it off the browser; it can be unrestricted (server requests have no Referer).
#
# Both are REQUIRED in prod: the sidecar raises at boot without the PRIVATE token
# (imagery + render), and the viewer ships a blank basemap without the PUBLIC one.
# Provision tokens at https://account.mapbox.com/access-tokens/.
MAPBOX_PUBLIC_TOKEN=change-me-mapbox-public-token
MAPBOX_PRIVATE_TOKEN=change-me-mapbox-private-token

# --- DigitalOcean Spaces (ADR-010: ONE bucket, prefixed) — REQUIRED ---
STORAGE_ACCESS_KEY=change-me-spaces-access-key
STORAGE_SECRET_KEY=change-me-spaces-secret-key
# Prod uses live Spaces (real data). The /health Spaces probe runs — do NOT set
# SKIP_SPACES_CHECK in production. (STORAGE_BUCKET/ENDPOINT are set in the compose
# environment: block, not here. The sidecar's storage boot check requires all four.)

# --- Sidecar environment (fail-fast boot checks) ---
# RoofTrace always uses REAL data; the sidecar checks every stage's real-path
# prerequisites at boot and RAISES on any missing one. Keep this "production".
SIDECAR_ENV=production

# IMPORTANT — REAL DATA IS THE DEFAULT (sidecar/app/flags.py). There are NO
# *_LIVE opt-up flags anymore, and you must NEVER set the test-only *_FIXTURE
# opt-down flags (IMAGERY_FIXTURE / LIDAR_FIXTURE / RENDER_IMAGES_FIXTURE /
# SAM2_BACKEND=local / STORAGE_LOCAL_ROOT) in this prod file — doing so would make
# production serve fake data. (The old LIDAR_LIVE=0 / IMAGERY_LIVE=0 lines here
# used to force prod onto fixtures; they are removed.)

# --- LiDAR ingest (sidecar) — REQUIRED ---
# Real USGS 3DEP COPC streaming, indexed by the real WESM GeoPackage. Mount the
# WESM.gpkg into the sidecar container (a volume) and point WESM_GPKG_PATH at it.
# The boot check requires the file to exist (and pdal to import).
WESM_GPKG_PATH=/data/WESM.gpkg

# --- SAM2 outline refinement (sidecar) — REQUIRED ---
# Real GPU SAM2 via Modal is the default; MODAL_TOKEN_ID + MODAL_TOKEN_SECRET are
# required (the boot check raises without them). A Modal outage fails the refine
# stage rather than degrading to a stub — no fixtures in prod.
MODAL_TOKEN_ID=change-me-modal-token-id
MODAL_TOKEN_SECRET=change-me-modal-token-secret

# --- Imagery fetch (sidecar) — real by default ---
# The geometry pipeline fetches satellite imagery from Mapbox (Static Images API,
# ADR-002 as amended), using the MAPBOX_PRIVATE_TOKEN set above (server-side) — no
# separate credential. (NAIP/AWS was dropped: its S3 buckets are requester-pays,
# not free anonymous.) Real by default — nothing extra to set here.

# --- iOS capture fusion / ICP (sidecar) — always real ---
# Real Open3D point-to-plane ICP (ADR-007) always runs; the boot check verifies
# open3d is importable and raises if the image is broken. Nothing to set here.

# --- iOS photo overlay / projection (sidecar) — always real ---
# The real pinhole projection + trimesh ray-cast occlusion + SVG composite of
# measured facets onto the captured iOS photo (ADR-019) is the default; the boot
# check verifies trimesh/rtree/svgwrite are importable and raises if the image is
# broken. Nothing to set here.

# NOTE: GIT_SHA is NOT set here — infra/deploy.sh injects it via compose
# interpolation (a git-sha.env it writes each deploy), and the compose
# `environment:` block takes precedence over this env_file. A manual
# `docker compose up` without that file defaults GIT_SHA to "unknown".

# --- Roof report PDF + map rendering (ADR-014) ---
# The report PDF / map render also uses MAPBOX_PRIVATE_TOKEN (server-side) —
# already set once above (do NOT add a second assignment here; a duplicate key
# silently lets the last one win).
