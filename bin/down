#!/usr/bin/env ruby
# Stop the local dev stack started by bin/dev / bin/setup.
#
#   bin/down            stop the sidecar container + the rt-pg Postgres container
#                       (Postgres data is PRESERVED — the container is stopped,
#                       not removed, so the next bin/setup/bin/dev reuses it).
#   bin/down --rm-db    ALSO remove the rt-pg container and its data volume
#                       (destructive — wipes the local dev/test database).
#
# bin/dev runs Rails/css/js in the foreground via foreman; those stop when you
# Ctrl-C bin/dev. This handles the two detached Docker containers that outlive it.

require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)
SIDECAR = "rooftrace-sidecar-dev"
PG = "rt-pg"

def container_exists?(name)
  system("docker ps -a --filter 'name=^/#{name}$' --format '{{.Names}}' | grep -q '^#{name}$'")
end

def container_running?(name)
  system("docker ps --filter 'name=^/#{name}$' --filter status=running --format '{{.Names}}' | grep -q '^#{name}$'")
end

FileUtils.chdir APP_ROOT do
  unless system("docker info > /dev/null 2>&1")
    abort "Docker is not available — nothing to stop."
  end

  puts "== Sidecar container (#{SIDECAR}) =="
  if container_running?(SIDECAR)
    # Started with --rm by Procfile.dev, so stopping removes it.
    system("docker stop #{SIDECAR} > /dev/null") && puts("   stopped.")
  elsif container_exists?(SIDECAR)
    system("docker rm -f #{SIDECAR} > /dev/null") && puts("   removed (was not running).")
  else
    puts "   not running."
  end

  puts "\n== Postgres container (#{PG}) =="
  if ARGV.include?("--rm-db")
    if container_exists?(PG)
      system("docker rm -f #{PG} > /dev/null") && puts("   REMOVED (data wiped — --rm-db).")
    else
      puts "   not present."
    end
  elsif container_running?(PG)
    # Stop only — preserve the data so the next run reuses the same DB.
    system("docker stop #{PG} > /dev/null") && puts("   stopped (data preserved; --rm-db to wipe).")
  elsif container_exists?(PG)
    puts "   already stopped (data preserved)."
  else
    puts "   not present."
  end

  puts "\n== Done =="
  puts "   Foreground processes (Rails/css/js) stop when you Ctrl-C bin/dev."
end
