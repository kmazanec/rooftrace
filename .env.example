# Local development env template. Copy to `.env` (gitignored) and edit as needed:
#
#   cp .env.example .env
#
# `dotenv-rails` auto-loads `.env` in dev/test. EVERYTHING here has a working
# default (or is only needed for a live external service), so a bare `.env`
# copy — or no `.env` at all — boots the app against the local stack. Uncomment
# and fill a value only when you want that specific live integration.
#
# This is NOT the production secret file — that's ops/.env.example, placed by an
# operator at /etc/rooftrace/.env on the droplet.

# --- Database -------------------------------------------------------------
# config/database.yml already defaults dev/test to the local PostGIS container
# (localhost:5433, rooftrace/devpassword). Only set these to point elsewhere.
# DATABASE_HOST=localhost
# DATABASE_PORT=5433
# DATABASE_USERNAME=rooftrace
# DATABASE_PASSWORD=devpassword

# --- Rails <-> Python sidecar (ADR-008) -----------------------------------
# `bin/dev` runs the sidecar on SIDECAR_PORT (default 8001). If 8001 is taken on
# your machine, set SIDECAR_PORT here AND point SIDECAR_URL at the same port.
# SIDECAR_PORT=8001
# SIDECAR_URL=http://localhost:8001
# Shared bearer between Rails and the sidecar. Any non-empty value works
# locally as long as both sides agree.
SIDECAR_SHARED_SECRET=dev-only-secret

# --- Dev login (ADR-016) --------------------------------------------------
# Submit routes are gated by a single dev login. Unset in dev = login disabled
# warning at boot (you can still hit public/share routes). To actually log in,
# set a username + a bcrypt digest of the password:
#   bin/rails runner 'puts BCrypt::Password.create("yourpassword")'
# DEMO_USERNAME=demo
# DEMO_PASSWORD_DIGEST=$2a$12$...

# --- DigitalOcean Spaces (ADR-010) ----------------------------------------
# Blob storage. Leave unset locally and the sidecar's storage helper reads from
# STORAGE_LOCAL_ROOT (fixtures/disk) instead of live Spaces. SKIP_SPACES_CHECK=1
# skips the /health Spaces probe so /health stays green without credentials.
SKIP_SPACES_CHECK=1
# STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
# STORAGE_REGION=nyc3
# STORAGE_BUCKET=rooftrace
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# --- VLM feature detection (OpenRouter, ADR-006) --------------------------
# Detection is stubbed in tests; a real run needs an OpenRouter key. Without it,
# FeatureDetector::OpenRouter raises only when actually called (boot just warns).
# The detector reaches every candidate model through OpenRouter's OpenAI-compatible
# API, so swapping models is a one-line OPENROUTER_MODEL change.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash
# CONFIDENCE_THRESHOLD=0.6            # below this, a detection is re-verified
# FEATURE_DETECTOR=openrouter        # detector implementation to use
# Comma-separated host suffix allowlist for tiles sent to the model (SSRF guard).
# Defaults to the Spaces CDN; set to add a local tile host.
# IMAGE_TILE_HOST_ALLOWLIST=

# --- LiDAR ingest (sidecar, ADR-003) --------------------------------------
# Live USGS 3DEP COPC streaming + the real WESM GeoPackage. Off by default;
# tests/dev use a fixture WESM index. Set LIDAR_LIVE=1 + a real .gpkg to enable.
# LIDAR_LIVE=1
# WESM_GPKG_PATH=/path/to/wesm.gpkg

# --- Outline refinement (SAM2, sidecar, ADR-005) --------------------------
# Backend: "local" (deterministic stub, default) or "modal" (real GPU SAM2).
# modal needs Modal tokens; without them it warns and falls back to the stub.
# SAM2_BACKEND=local
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# --- Address resolver (sidecar, ADR-004) ----------------------------------
# Nominatim TOS requires a meaningful UA naming the project + a REAL contact.
# Nominatim 403s a generic/placeholder UA — and an example.com contact counts
# as placeholder — so put your actual email here, not example.com. Without a
# valid UA every geocode (the pipeline's first stage) hard-fails with a 422.
# NOMINATIM_USER_AGENT=rooftrace-dev (your-real-email@your-domain.com)
# Regrid parcel lookups need a free-tier key; unset = parcel degrades to null.
# REGRID_API_KEY=
