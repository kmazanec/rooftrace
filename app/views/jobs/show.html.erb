<%# Job status page. Subscribes to the per-job Turbo Stream so Job#advance_to!
    and #fail_with! broadcast live replacements of the _status partial. %>
<% content_for :head do %>
  <%= stylesheet_link_tag "cc", media: "all" %>
  <%= stylesheet_link_tag "status", media: "all" %>
<% end %>

<%= turbo_stream_from @job, :status %>

<section class="cc-status">
  <%= image_tag "brand/rooftrace-wordmark.svg",
        class: "cc-status__wordmark",
        alt: "RoofTrace",
        "aria-label": "RoofTrace" %>

  <div class="cc-status__card">
    <p class="cc-eyebrow">Roof measurement</p>
    <h1 class="cc-status__address"><%= @job.address %></h1>

    <%= render "jobs/status", job: @job %>

    <%# Additive on-site-capture (ICP fusion) status — its own Turbo stream so a
        fusion broadcast never clobbers the base pipeline status (ADR-007). %>
    <%= turbo_stream_from @job, :fusion_status %>
    <%= render "jobs/fusion_status", job: @job, state: :idle, icp_rmse_m: nil %>
  </div>
</section>
