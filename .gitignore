# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files, except the committed dev template.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
config/master.key

# Kamal secrets
/.kamal/secrets
**/.kamal/secrets

# Node (Tailwind asset builds)
/node_modules/
/yarn-error.log
/yarn-debug.log*

# Python sidecar
sidecar/.venv/
sidecar/.pytest_cache/
sidecar/.ruff_cache/
**/__pycache__/
*.py[cod]

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Worktrees (kmaz-feature-builder workflow)
/worktrees/

# Local backups created during F-01 scaffolding
*.bak

/app/assets/builds/*
!/app/assets/builds/.keep

# Production secrets (deploy-time, never committed)
ops/.env.production

# Deploy-written GIT_SHA interpolation file (infra/deploy.sh)
ops/git-sha.env
/etc/rooftrace/git-sha.env
