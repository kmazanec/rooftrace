# Template for the operator-placed secret file at /etc/rooftrace/.env on the
# droplet. Per the droplet convention (.infra/NEW_APP.md §4.1), the operator
# places this ONCE as root:
#
#   sudo install -m 640 -o root -g gitlab-runner /dev/stdin /etc/rooftrace/.env <<'EOF'
#   ...contents below, with real values...
#   EOF
#   sudo /usr/local/sbin/audit-secrets.sh   # verify perms
#
# The GitLab CI deploy job (infra/deploy.sh) reads it via compose `env_file:`.
# It is never committed and never lives in a bind-mount the container can write.
# GIT_SHA is rewritten by infra/deploy.sh on each deploy (the deployed SHA).

# --- Postgres ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Database URLs (composed from POSTGRES_PASSWORD; the host is the
#     rooftrace-postgres container on the internal network). Rails reads the
#     primary DATABASE_URL; Solid Queue/Cache/Cable need their own pools. ---
DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production
QUEUE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_queue
CACHE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cache
CABLE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cable

# --- Rails ---
# Generate with: bin/rails secret
SECRET_KEY_BASE=change-me-run-bin-rails-secret

# --- Rails <-> sidecar bearer (ADR-008). Generate: openssl rand -hex 32 ---
SIDECAR_SHARED_SECRET=change-me-openssl-rand-hex-32

# --- DigitalOcean Spaces (ADR-010, amended F-01: ONE bucket, prefixed) ---
STORAGE_ACCESS_KEY=change-me-spaces-access-key
STORAGE_SECRET_KEY=change-me-spaces-secret-key

# Set to 1 to skip the live Spaces write/read probe in /health (e.g. before the
# Spaces credentials are provisioned). 0/unset = probe runs.
SKIP_SPACES_CHECK=1

# NOTE: GIT_SHA is NOT set here — infra/deploy.sh injects it via compose
# interpolation (a git-sha.env it writes each deploy), and the compose
# `environment:` block takes precedence over this env_file. A manual
# `docker compose up` without that file defaults GIT_SHA to "unknown".
