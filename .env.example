# Local development env template. Copy to `.env` (gitignored) and edit:
#
#   cp .env.example .env
#
# `dotenv-rails` auto-loads `.env` in dev/test.
#
# IMPORTANT — RoofTrace's running product (dev AND prod) ALWAYS uses REAL data.
# There are NO fixture fallbacks in the running app. The vars marked REQUIRED
# below MUST be set for the dev app to boot — `bin/setup` checks them and aborts
# with a list if any are missing, and the sidecar raises at boot otherwise. The
# real geospatial stack (pdal/gdal/rasterio/playwright) runs inside the sidecar
# DOCKER IMAGE that `bin/dev` launches, so you don't install conda on your host.
#
# Fixtures exist ONLY as an explicit opt-DOWN for the automated TEST suites
# (CI + local rspec/pytest): IMAGERY_FIXTURE / LIDAR_FIXTURE / RENDER_IMAGES_FIXTURE
# / SAM2_BACKEND=local / STORAGE_LOCAL_ROOT. The test suites set these themselves
# (sidecar/tests/conftest.py, spec/support/real_sidecar.rb). DO NOT set them in a
# dev/prod `.env` — that would make the running app serve fake data.
#
# This is NOT the production secret file — that's ops/.env.example, placed by an
# operator at /etc/rooftrace/.env on the droplet.

# --- Database -------------------------------------------------------------
# config/database.yml already defaults dev/test to the local PostGIS container
# (localhost:5433, rooftrace/devpassword). Only set these to point elsewhere.
# DATABASE_HOST=localhost
# DATABASE_PORT=5433
# DATABASE_USERNAME=rooftrace
# DATABASE_PASSWORD=devpassword

# --- Rails <-> Python sidecar (ADR-008) -----------------------------------
# `bin/dev` runs the sidecar on SIDECAR_PORT (default 3011, bound to 127.0.0.1).
# If 3011 is taken, set SIDECAR_PORT here AND point SIDECAR_URL at the same port.
# Use 127.0.0.1 (not localhost): an IPv6-only listener on this port would else
# hijack "localhost" and 404 every POST. The web app keeps port 3000; other local
# services use the 3010-3020 range.
# SIDECAR_PORT=3011
# SIDECAR_URL=http://127.0.0.1:3011
# Shared bearer between Rails and the sidecar. Any non-empty value works
# locally as long as both sides agree.
SIDECAR_SHARED_SECRET=dev-only-secret

# --- Dev login (ADR-016) --------------------------------------------------
# Submit routes are gated by a single dev login. Unset in dev = login disabled
# warning at boot (you can still hit public/share routes). To actually log in,
# set a username + a bcrypt digest of the password:
#   bin/rails runner 'puts BCrypt::Password.create("yourpassword")'
# DEMO_USERNAME=demo
# DEMO_PASSWORD_DIGEST=$2a$12$...

# --- DigitalOcean Spaces (ADR-010) — REQUIRED -----------------------------
# Real blob storage. The dev app uses live Spaces (the sidecar/Rails write
# artifacts, cache, uploads here). All four are REQUIRED; the sidecar raises at
# boot without them. (Only the test suites swap in STORAGE_LOCAL_ROOT.)
STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
STORAGE_REGION=nyc3
STORAGE_BUCKET=rooftrace
STORAGE_ACCESS_KEY=your-spaces-access-key
STORAGE_SECRET_KEY=your-spaces-secret-key

# --- VLM feature detection (OpenRouter, ADR-006) — REQUIRED ---------------
# Real VLM detection (vents/chimneys/etc) runs on every job. REQUIRED — a missing
# key fails bin/setup. The detector reaches every candidate model through
# OpenRouter's OpenAI-compatible API, so swapping models is a one-line change.
OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=google/gemini-2.5-flash
# CONFIDENCE_THRESHOLD=0.6            # below this, a detection is re-verified
# FEATURE_DETECTOR=openrouter        # detector implementation to use
# Comma-separated host suffix allowlist for tiles sent to the model (SSRF guard).
# Defaults to the Spaces CDN; set to add a local tile host.
# IMAGE_TILE_HOST_ALLOWLIST=

# --- Mapbox (ADR-002/004/014) — TWO tokens, split by EXPOSURE -------------
# MAPBOX_PUBLIC_TOKEN — BROWSER only. Embedded in the report-viewer page so the
# browser's MapLibre fetches satellite raster tiles (ADR-002). Use a pk.* token
# URL-restricted to your domain(s); it is not a secret. REQUIRED in prod (the
# viewer ships a blank basemap without it; dev/test only warn).
MAPBOX_PUBLIC_TOKEN=pk.your-mapbox-public-token

# MAPBOX_PRIVATE_TOKEN — SERVER only. Every server-side Mapbox call reads it:
#   • geometry-pipeline imagery (sidecar, Static Images API — Mapbox replaced
#     NAIP, whose AWS buckets are requester-pays)
#   • top-down map render for the PDF (sidecar, headless MapLibre)
#   • PDF static-image fallback (Rails)
#   • address-entry autocomplete (Rails /address_suggestions → Search Box
#     /suggest — SUGGEST-ONLY: never /retrieve, never stores a Mapbox geocode, so
#     Nominatim stays the authoritative geocoder per ADR-004)
# REQUIRED — the sidecar raises at boot without it (imagery + render). Keep it off
# the browser; it can be unrestricted (server requests have no Referer). (Real
# imagery is on by default; the test suites set IMAGERY_FIXTURE=1 /
# RENDER_IMAGES_FIXTURE=1 and inject the token in-process.)
MAPBOX_PRIVATE_TOKEN=pk.your-mapbox-private-token

# --- LiDAR ingest (sidecar, ADR-003) — REQUIRED ---------------------------
# Real USGS 3DEP COPC streaming, indexed by the real WESM GeoPackage. `bin/setup`
# downloads WESM.gpkg (~3.5 GB) to sidecar/data/ and the dev sidecar container
# mounts it at /data/WESM.gpkg (WESM_GPKG_PATH below is set by Procfile.dev for
# the container). Real LiDAR is on by default; the test suites set LIDAR_FIXTURE=1
# to use a small fixture index instead. You normally don't set WESM_GPKG_PATH here.
# WESM_GPKG_PATH=/data/WESM.gpkg

# --- Outline refinement (SAM2, sidecar, ADR-005) — REQUIRED ---------------
# Real SAM2 segmentation runs on Modal GPUs by default; REQUIRED tokens. A Modal
# outage fails the refine stage (502) — no silent stub fallback in the running
# product. (The test suites set SAM2_BACKEND=local for the deterministic stub.)
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# --- Address resolver (sidecar, ADR-004) ----------------------------------
# Nominatim TOS requires a meaningful UA naming the project + a REAL contact.
# Nominatim 403s a generic/placeholder UA — and an example.com contact counts
# as placeholder — so put your actual email here, not example.com. Without a
# valid UA every geocode (the pipeline's first stage) hard-fails with a 422.
# NOMINATIM_USER_AGENT=rooftrace-dev (your-real-email@your-domain.com)
# Regrid parcel lookups need a free-tier key; unset = parcel degrades to null.
# REGRID_API_KEY=
