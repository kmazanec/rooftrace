<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>
	<key>UIAppFonts</key>
	<array>
		<string>Archivo-ExtraBold.ttf</string>
		<string>Inter-Regular.ttf</string>
		<string>Inter-Medium.ttf</string>
		<string>Inter-SemiBold.ttf</string>
		<string>Inter-Bold.ttf</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- Backend base URL injected from the build's xcconfig (BACKEND_URL). Read by AppConfig. -->
	<key>BackendURL</key>
	<string>$(BACKEND_URL)</string>
	<!-- Permission usage strings (required or the app crashes on first prompt). -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>RoofTrace records a GPS fix at the start of your capture so the roof measurement can be aligned to your property.</string>
	<key>NSCameraUsageDescription</key>
	<string>RoofTrace uses the camera and LiDAR scanner to photograph and measure the roof during the guided walk-around.</string>
	<key>NSMotionUsageDescription</key>
	<string>RoofTrace records device orientation with each photo to help align the roof measurement.</string>
	<!-- Deep-link URL scheme: rooftrace://capture?token=...&job_id=... -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>dev.biograph.rooftrace</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>rooftrace</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
