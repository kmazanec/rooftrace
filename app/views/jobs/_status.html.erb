<%# Per-job status partial — the F-10↔F-11 broadcast seam (C0.2).
    Job#advance_to!/#fail_with! broadcast a Turbo Stream `replace` of this
    partial to the per-job stream `[job, :status]`, targeting `dom_id(job, :status)`.
    The outer div id MUST remain `dom_id(job, :status)` for the contract to hold.
    The local variable MUST be named `job`. %>

<% stages = job_pipeline_stages %>
<% status_index = Job.statuses.keys.each_with_index.to_h %>
<% current_index = status_index[job.status.to_s] %>

<div id="<%= dom_id(job, :status) %>" class="job-status" data-job-status="<%= job.status %>">

  <% if job.failed? %>
    <%# ---------------------------------------------------------------- %>
    <%# Failure state — plain-language COMPANY.md voice, back to form    %>
    <%# ---------------------------------------------------------------- %>
    <div class="job-status__failure" role="alert">
      <p class="job-status__failure-message">
        <% if job.last_error.present? %>
          <%= job.last_error %>
        <% else %>
          Something went wrong generating this report — please try again.
        <% end %>
      </p>
      <%= link_to "Try another address", new_job_path, class: "job-status__back-link" %>
    </div>

  <% elsif job.ready? %>
    <%# ---------------------------------------------------------------- %>
    <%# Ready state — all stages complete, link to the report             %>
    <%# ---------------------------------------------------------------- %>
    <div class="job-status__ready">
      <ul class="job-status__stages" aria-label="Pipeline progress">
        <% stages.each do |_key, label| %>
          <li class="job-status__stage job-status__stage--completed">
            <span class="job-status__stage-icon" aria-hidden="true">&#10003;</span>
            <span class="job-status__stage-label"><%= label %></span>
          </li>
        <% end %>
      </ul>

      <p class="job-status__ready-message">Measurement complete.</p>
      <%= link_to "View report", report_job_path(job), class: "report-cta job-status__report-link" %>
    </div>

  <% else %>
    <%# ---------------------------------------------------------------- %>
    <%# In-progress state — checkmarks for completed stages, indicator   %>
    <%# on the active stage                                               %>
    <%# ---------------------------------------------------------------- %>
    <ul class="job-status__stages" aria-label="Pipeline progress">
      <% stages.each do |stage_key, label| %>
        <%
          stage_index = status_index[stage_key.to_s]
          stage_state = if current_index && stage_index < current_index
            "completed"
          elsif current_index && stage_index == current_index
            "active"
          else
            "pending"
          end
        %>
        <li class="job-status__stage job-status__stage--<%= stage_state %>"
            aria-current="<%= stage_state == 'active' ? 'step' : nil %>">
          <span class="job-status__stage-icon" aria-hidden="true">
            <% if stage_state == "completed" %>&#10003;<% elsif stage_state == "active" %>&bull;<% else %>&circ;<% end %>
          </span>
          <span class="job-status__stage-label"><%= label %></span>
          <% if stage_state == "active" %>
            <span class="job-status__spinner" aria-label="In progress" role="status"></span>
          <% end %>
        </li>
      <% end %>
    </ul>

    <p class="job-status__working-message">
      Working on it — this usually takes about a minute.
    </p>
  <% end %>

</div>
