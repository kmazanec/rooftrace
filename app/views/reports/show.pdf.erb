<%#
  Roof Measurement Report — print/PDF layout (ADR-014).

  Rendered by ReportPdf under layouts/report_print (which links the `report`
  stylesheet). Assigns:
    @job              (Job)
    @measurement      (Measurement) — orchestrator source-of-truth shape
    @map_image_url    (String|nil)  — signed URL to the sidecar/fallback map PNG
    @fallback_warning (String|nil)  — set when the static-map fallback engaged
    @presenter        (PdfReportPresenter) — all derived display values

  Brand rule: orange appears ONLY in the header bar. Low-confidence facets are
  shown (not hidden) in muted gray — honest-uncertainty.
%>

<%# Orange PDF header bar — wordmark + document title. The wordmark is inlined
    (not <img src>) because Grover renders this HTML with no base URL to resolve
    /assets paths against — see ReportsHelper#inline_brand_svg. %>
<div class="report-header-bar print-only">
  <%= inline_brand_svg "rooftrace-wordmark-onorange.svg",
        aria_label: "RoofTrace",
        css_class: "report-header-wordmark" %>
  <span class="report-header-title">Roof Measurement Report</span>
</div>

<div class="report-card report-root">
  <h1 class="report-title">Roof Measurement Report</h1>

  <%# Subject block: address + geocoded lat/lng + generated timestamp. %>
  <p class="report-subtitle"><%= h @presenter.address %></p>
  <p style="font-size:0.8rem;color:#6B7280;margin-top:-0.5rem;">
    <% if @presenter.geocode_lat && @presenter.geocode_lon %>
      <%= "#{@presenter.geocode_lat}, #{@presenter.geocode_lon}" %> ·
    <% end %>
    Generated <%= @presenter.generated_at_display("%Y-%m-%d %H:%M %Z") %>
  </p>

  <%# Headline measurements. %>
  <table class="report-table" style="margin-top:1rem;">
    <caption>Summary</caption>
    <tbody>
      <tr>
        <td>Total area</td>
        <td><span class="report-measurement"><strong><%= @measurement.total_area_sq_ft.present? ? "#{number_with_delimiter(@measurement.total_area_sq_ft.to_f.round(0))} sq ft" : "—" %></strong></span></td>
      </tr>
      <tr>
        <td>Total perimeter</td>
        <td><span class="report-measurement"><%= @measurement.total_perimeter_ft.present? ? "#{number_with_delimiter(@measurement.total_perimeter_ft.to_f.round(0))} ft" : "—" %></span></td>
      </tr>
      <tr>
        <td>Primary pitch</td>
        <td><span class="report-measurement"><%= @presenter.predominant_pitch_ratio.present? ? "#{@presenter.predominant_pitch_ratio.to_f.round(1)}/12#{@presenter.predominant_pitch_degrees ? " (#{@presenter.predominant_pitch_degrees}°)" : ''}" : "—" %></span></td>
      </tr>
      <tr>
        <td>Facets</td>
        <td><span class="report-measurement"><%= @presenter.facets.size %></span></td>
      </tr>
      <tr>
        <td>Source</td>
        <td><span class="report-source"><%= methodology_label(@measurement.source) %></span></td>
      </tr>
      <tr>
        <td>Overall confidence</td>
        <td><span class="report-confidence" data-level="<%= @presenter.conf_level(@measurement.confidence) %>"><%= @measurement.confidence.present? ? "#{(@measurement.confidence.to_f * 100).round}%" : "—" %></span></td>
      </tr>
    </tbody>
  </table>

  <%# Roof diagram — sidecar-rendered top-down map (or Mapbox Static fallback). %>
  <% if @map_image_url.present? %>
    <div class="report-diagram">
      <%= image_tag @map_image_url, alt: "Top-down roof diagram", style: "max-width:100%;height:auto;" %>
    </div>
  <% else %>
    <div class="report-diagram" role="img" aria-label="Roof diagram unavailable">
      <p style="color:#9CA3AF;font-size:0.8rem;">Roof diagram unavailable.</p>
    </div>
  <% end %>

  <%# Per-facet table. Low-confidence rows are shown muted, never hidden. %>
  <table class="report-table">
    <caption>Facet measurements</caption>
    <thead>
      <tr>
        <th scope="col">Facet</th>
        <th scope="col">Area (sq ft)</th>
        <th scope="col">Pitch</th>
        <th scope="col">Source</th>
        <th scope="col">Confidence</th>
      </tr>
    </thead>
    <tbody>
      <% @presenter.facets.each do |f| %>
        <tr>
          <td class="report-facet-name"><%= h f["facet_id"] %></td>
          <td><span class="report-measurement"><%= f["area_sq_ft"].present? ? "#{number_with_delimiter(f["area_sq_ft"].to_f.round(0))} sq ft" : "—" %></span></td>
          <td><span class="report-measurement"><%= @presenter.facet_pitch_label(f) %></span></td>
          <td><span class="report-source"><%= methodology_label(f["source"]) %></span></td>
          <td><span class="report-confidence" data-level="<%= @presenter.conf_level(f["confidence"]) %>"><%= f["confidence"].present? ? "#{(f["confidence"].to_f * 100).round}%" : "—" %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%# Features table: label, count, average confidence. %>
  <table class="report-table">
    <caption>Detected features</caption>
    <thead>
      <tr>
        <th scope="col">Feature</th>
        <th scope="col">Count</th>
        <th scope="col">Avg confidence</th>
      </tr>
    </thead>
    <tbody>
      <% if @presenter.feature_rows.empty? %>
        <tr><td colspan="3" style="color:#9CA3AF;">No features detected.</td></tr>
      <% else %>
        <% @presenter.feature_rows.each do |r| %>
          <tr>
            <td><%= feature_label_display(r[:label]) %></td>
            <td><span class="report-measurement"><%= r[:count] %></span></td>
            <td><span class="report-confidence" data-level="<%= @presenter.conf_level(r[:avg]) %>"><%= r[:avg] ? "#{(r[:avg] * 100).round}%" : "—" %></span></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>

  <%# Site-visit block (print only; omitted when no completed CaptureSession).
      The "GPS-verified" claim is gated on real GPS proximity — see ReportPdf. %>
  <%= render partial: "reports/visit_verification", formats: [ :html ],
        locals: { visit_verification: @visit_verification } %>

  <%# On-site evidence / visualization strip (omitted when there are none). The
      ordered, capped list is built by ReportPdf; this partial is kind-agnostic. %>
  <%= render partial: "reports/evidence_photos", formats: [ :html ],
        locals: { evidence_photos: (@evidence_photos || []) } %>

  <%# Methodology footnote — generated from provenance, not hardcoded. %>
  <%= render partial: "reports/methodology", formats: [ :html ],
        locals: { methodology_sentences: Array(@methodology_sentences) } %>

  <%# Limitations & confidence section (print only). %>
  <%= render partial: "reports/limitations", formats: [ :html ],
        locals: { measurement: @measurement } %>

  <%# Degraded-view warning (only when the static-map fallback engaged). %>
  <% if @fallback_warning.present? %>
    <p class="report-fallback-warning" style="font-size:0.75rem;color:#6B7280;border:1px solid #E5E7EB;border-radius:4px;padding:0.5rem 0.75rem;margin-bottom:1rem;">
      &#9888; <%= h @fallback_warning %>
    </p>
  <% end %>

  <%# Signature line (print only — reuses the existing .report-signature-block CSS). %>
  <div class="report-signature-block print-only">
    <div>
      <div class="report-signature-field">&nbsp;</div>
      <div class="report-signature-label">Reviewed by</div>
    </div>
    <div>
      <div class="report-signature-field">&nbsp;</div>
      <div class="report-signature-label">Date</div>
    </div>
  </div>

  <%# Attribution footer (print). %>
  <div class="report-attribution print-only">
    <span>Data: <%= @presenter.attribution_names.join(", ") %></span>
    <span>Generated <%= @presenter.generated_at_display("%Y-%m-%d") %></span>
  </div>
</div>
