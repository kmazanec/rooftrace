<% content_for :head do %>
  <%= stylesheet_link_tag "cc", media: "all" %>
<% end %>

<section class="cc-hero">
  <%= image_tag "brand/rooftrace-wordmark.svg",
        class: "cc-hero__wordmark",
        alt: "RoofTrace",
        "aria-label": "RoofTrace" %>

  <hr class="cc-hero__rule">
  <p class="cc-eyebrow">New roof measurement</p>
  <h1 class="cc-display cc-hero__headline">Drop an<br>address.</h1>
  <p class="cc-lede">
    Enter a property address and RoofTrace fuses satellite imagery with public
    LiDAR into a measured roof report — area, per-facet pitch, and detected
    features.
  </p>

  <div class="cc-hero__card">
    <% if @job.errors.any? %>
      <div class="cc-errors" role="alert">
        <% @job.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @job, url: jobs_path do |f| %>
      <%# Address typeahead (ADR-004 amended): Mapbox /suggest powers in-session,
          non-persisted suggestions via the same-origin proxy; selecting one only
          fills this field. The form still posts free text — Nominatim remains the
          authoritative geocoder. Progressive enhancement: with JS off this is a
          plain text field. WAI-ARIA combobox pattern. %>
      <div class="cc-field"
           data-controller="address-autocomplete"
           data-address-autocomplete-url-value="<%= address_suggestions_path %>">
        <%= f.label :address, "Property address", class: "cc-field__label" %>
        <%= f.text_field :address,
              class: "cc-input",
              autofocus: true,
              autocomplete: "off",
              placeholder: "123 Main St, Springfield, IL 62701",
              role: "combobox",
              "aria-autocomplete": "list",
              "aria-expanded": "false",
              "aria-controls": "address-suggestions",
              data: { "address-autocomplete-target": "input", action: "input->address-autocomplete#onInput keydown->address-autocomplete#onKeydown" } %>
        <ul id="address-suggestions"
            class="cc-autocomplete"
            role="listbox"
            hidden
            data-address-autocomplete-target="listbox"></ul>
        <p class="cc-hint">
          Try a US residential address; supports street + city/state + optional ZIP.
        </p>
      </div>

      <div class="cc-hero__actions">
        <%= f.submit "Start measurement",
              class: "cc-btn cc-btn--primary cc-btn--block" %>
      </div>
    <% end %>
  </div>
</section>
