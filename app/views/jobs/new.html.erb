<% content_for :head do %>
  <%= stylesheet_link_tag "cc", media: "all" %>
<% end %>

<section class="cc-hero">
  <%= image_tag "brand/rooftrace-wordmark.svg",
        class: "cc-hero__wordmark",
        alt: "RoofTrace",
        "aria-label": "RoofTrace" %>

  <hr class="cc-hero__rule">
  <p class="cc-eyebrow">New roof measurement</p>
  <h1 class="cc-display cc-hero__headline">Drop an<br>address.</h1>
  <p class="cc-lede">
    Enter a property address and RoofTrace fuses satellite imagery with public
    LiDAR into a measured roof report — area, per-facet pitch, and detected
    features.
  </p>

  <div class="cc-hero__card">
    <% if @job.errors.any? %>
      <div class="cc-errors" role="alert">
        <% @job.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @job, url: jobs_path do |f| %>
      <div class="cc-field">
        <%= f.label :address, "Property address", class: "cc-field__label" %>
        <%= f.text_field :address,
              class: "cc-input",
              autofocus: true,
              placeholder: "123 Main St, Springfield, IL 62701" %>
        <p class="cc-hint">
          Try a US residential address; supports street + city/state + optional ZIP.
        </p>
      </div>

      <div class="cc-hero__actions">
        <%= f.submit "Start measurement",
              class: "cc-btn cc-btn--primary cc-btn--block" %>
      </div>
    <% end %>
  </div>
</section>
