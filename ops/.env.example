# Template for the operator-placed secret file at /etc/rooftrace/.env on the
# droplet. Per the droplet convention (.infra/NEW_APP.md §4.1), the operator
# places this ONCE as root:
#
#   sudo install -m 640 -o root -g gitlab-runner /dev/stdin /etc/rooftrace/.env <<'EOF'
#   ...contents below, with real values...
#   EOF
#   sudo /usr/local/sbin/audit-secrets.sh   # verify perms
#
# The GitLab CI deploy job (infra/deploy.sh) reads it via compose `env_file:`.
# It is never committed and never lives in a bind-mount the container can write.
# GIT_SHA is rewritten by infra/deploy.sh on each deploy (the deployed SHA).

# --- Postgres ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Database URLs (composed from POSTGRES_PASSWORD; the host is the
#     rooftrace-postgres container on the internal network). Rails reads the
#     primary DATABASE_URL; Solid Queue/Cache/Cable need their own pools. ---
DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production
QUEUE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_queue
CACHE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cache
CABLE_DATABASE_URL=postgres://rooftrace:change-me-strong-password@rooftrace-postgres:5432/rooftrace_production_cable

# --- Rails ---
# Generate with: bin/rails secret
SECRET_KEY_BASE=change-me-run-bin-rails-secret

# --- Rails <-> sidecar bearer (ADR-008). Generate: openssl rand -hex 32 ---
SIDECAR_SHARED_SECRET=change-me-openssl-rand-hex-32

# --- Dev login (ADR-016) — REQUIRED in production ---
# The submit surface is gated by a single dev login; the app raises at boot if
# these are unset in production. DEMO_PASSWORD_DIGEST is a bcrypt digest:
#   bin/rails runner 'puts BCrypt::Password.create("the-demo-password")'
DEMO_USERNAME=demo
DEMO_PASSWORD_DIGEST=change-me-bcrypt-digest

# --- VLM feature detection (ADR-006) — REQUIRED in production ---
# OpenRouter API key (openrouter.ai/keys). The detector reaches every candidate
# model (Gemini, GPT-4o, Claude, …) through OpenRouter's OpenAI-compatible API.
# The app raises at boot if unset in prod.
OPENROUTER_API_KEY=change-me-openrouter-api-key
# Optional: model slug to use (default google/gemini-2.5-flash).
# OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Mapbox satellite basemap (ADR-002) — REQUIRED in production ---
# Front-end-only PUBLIC token (pk.*) for the report viewer's Mapbox Satellite
# raster tiles. It is embedded in the report page so the browser's MapLibre can
# fetch tiles; the sidecar uses NAIP and needs no Mapbox credential. The app
# raises at boot if unset in prod (the viewer would otherwise show a blank map);
# in dev/test the viewer falls back to a neutral basemap with a notice.
# Provision a free public token at https://account.mapbox.com/access-tokens/.
MAPBOX_PUBLIC_TOKEN=change-me-mapbox-public-token

# --- DigitalOcean Spaces (ADR-010: ONE bucket, prefixed) ---
STORAGE_ACCESS_KEY=change-me-spaces-access-key
STORAGE_SECRET_KEY=change-me-spaces-secret-key

# Set to 1 to skip the live Spaces write/read probe in /health (e.g. before the
# Spaces credentials are provisioned). 0/unset = probe runs.
SKIP_SPACES_CHECK=1

# --- Sidecar environment (F-10.4 fail-fast boot checks) ---
# Controls the sidecar's raise-or-warn behaviour at boot:
#   production  → missing live-stage config RAISES at startup (deploy fails fast).
#   development → missing live-stage config WARNS; sidecar starts anyway.
# Set to "production" in the prod env file (the sidecar container reads this).
SIDECAR_ENV=production

# --- F-06 LiDAR ingest (sidecar) — required when LIDAR_LIVE=1 ---
# Set LIDAR_LIVE=1 to enable real USGS 3DEP COPC streaming.
# WESM_GPKG_PATH must point to the WESM GeoPackage file mounted in the container.
# Leave LIDAR_LIVE unset (or 0) in dev/CI; the sidecar uses a fixture index instead.
LIDAR_LIVE=0
# WESM_GPKG_PATH=/data/wesm/wesm_conus.gpkg

# --- Sidecar storage ---
# The sidecar resolves blob refs from DigitalOcean Spaces using the same Spaces
# credentials as the Rails app. If STORAGE_LOCAL_ROOT is unset, the sidecar uses
# live Spaces, and its boot check requires all four STORAGE_* vars in production.
# Split (matching the rails service): the two SECRET keys (STORAGE_ACCESS_KEY,
# STORAGE_SECRET_KEY, listed above) come from THIS env_file; the two non-secret
# values (STORAGE_BUCKET, STORAGE_ENDPOINT) are set in the sidecar's compose
# `environment:` block, NOT here — so do not add them to this file.

# --- F-07 SAM2 outline refinement (sidecar) — required when SAM2_BACKEND=modal ---
# "local" (default, deterministic stub) or "modal" (real GPU SAM2 via Modal).
# When SAM2_BACKEND=modal, MODAL_TOKEN_ID + MODAL_TOKEN_SECRET are required.
SAM2_BACKEND=local
# MODAL_TOKEN_ID=change-me-modal-token-id
# MODAL_TOKEN_SECRET=change-me-modal-token-secret

# --- Imagery fetch (sidecar) — gated by IMAGERY_LIVE=1 ---
# The live NAIP path uses anonymous public AWS Open Data (naip-visualization
# bucket) and rasterio for COG windowed reads.  No extra credentials needed
# beyond the storage vars already set above.  Set IMAGERY_LIVE=1 to enable
# real NAIP tiles; leave unset (or 0) in dev/CI for the deterministic fixture.
IMAGERY_LIVE=0

# --- iOS capture fusion / ICP (sidecar) — gated by FUSE_CAPTURE_LIVE=1 ---
# Set FUSE_CAPTURE_LIVE=1 to enable the real Open3D point-to-plane ICP alignment
# of the uploaded iOS ARKit capture mesh against the cached public-LiDAR cloud
# (ADR-007). When enabled, the sidecar boot check verifies open3d is importable
# and raises in production if the image is broken. Leave unset (or 0) in dev/CI;
# the fuse-capture tests drive the aligner directly with local fixtures.
FUSE_CAPTURE_LIVE=0

# NOTE: GIT_SHA is NOT set here — infra/deploy.sh injects it via compose
# interpolation (a git-sha.env it writes each deploy), and the compose
# `environment:` block takes precedence over this env_file. A manual
# `docker compose up` without that file defaults GIT_SHA to "unknown".

# --- Roof report PDF + map rendering (ADR-014) ---
# Mapbox public-scope token for the Static Images API fallback (and the sidecar
# headless-viewer satellite tiles). Required in production so a roof diagram is
# produced even when the sidecar's interactive map renderer is unavailable.
MAPBOX_PUBLIC_TOKEN=change-me-mapbox-public-token
